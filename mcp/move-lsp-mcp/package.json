{
  "name": "@sui-move/move-lsp-mcp",
  "version": "0.1.0",
  "description": "MCP server for Move language server integration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run test/e2e/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "vscode-languageserver-protocol": "^3.17.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}